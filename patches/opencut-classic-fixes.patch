@@ -38,6 +38,38 @@ export type SingleCharacterShortcutKey = `${Key}`;
 
 export type ShortcutKey = ModifierBasedShortcutKey | SingleCharacterShortcutKey;
 
+const MODIFIER_COMBOS: ReadonlySet<string> = new Set<ModifierKeys>([
+	"ctrl",
+	"alt",
+	"shift",
+	"ctrl+shift",
+	"alt+shift",
+	"ctrl+alt",
+	"ctrl+alt+shift",
+]);
+
+/**
+ * Runtime type guard for `ShortcutKey`.
+ *
+ * A valid shortcut is either a bare key (e.g. `"a"`, `"enter"`) or a modifier
+ * combination followed by a key (e.g. `"ctrl+shift+z"`). The modifier portion
+ * must exactly match one of the allowed `ModifierKeys` combinations.
+ */
+export function isShortcutKey(value: string): value is ShortcutKey {
+	const lastPlus = value.lastIndexOf("+");
+
+	// Bare single key (no modifier). Also handles the literal "+" key edge case
+	// where there is no modifier prefix.
+	if (lastPlus <= 0) {
+		return isKey(value);
+	}
+
+	const modifiers = value.slice(0, lastPlus);
+	const key = value.slice(lastPlus + 1);
+
+	return MODIFIER_COMBOS.has(modifiers) && isKey(key);
+}
+
 export type KeybindingConfig = {
 	[key in ShortcutKey]?: TActionWithOptionalArgs;
 };
