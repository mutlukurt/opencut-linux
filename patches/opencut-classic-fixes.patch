--- a/apps/web/src/actions/definitions.ts
+++ b/apps/web/src/actions/definitions.ts
@@ -152,6 +152,31 @@ export const ACTIONS = {
 
 export type TAction = keyof typeof ACTIONS;
 
+/**
+ * Actions that require a payload with mandatory (non-optional) arguments.
+ * These are excluded from `TActionWithOptionalArgs`.
+ */
+const ACTIONS_WITH_REQUIRED_ARGS: ReadonlySet<string> = new Set([
+	"remove-media-asset",
+	"remove-media-assets",
+]);
+
+/**
+ * Runtime type guard for `TActionWithOptionalArgs`.
+ *
+ * Returns `true` when the value is a known action that can be invoked without
+ * mandatory arguments (i.e. every action except those requiring a payload).
+ */
+export function isActionWithOptionalArgs(
+	value: unknown,
+): value is TActionWithOptionalArgs {
+	return (
+		typeof value === "string" &&
+		Object.hasOwn(ACTIONS, value) &&
+		!ACTIONS_WITH_REQUIRED_ARGS.has(value)
+	);
+}
